{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start:production": "NODE_ENV=production npm run start",
    "start:development": "NODE_ENV=development npm run start",
    "start": "chmod +x ./scripts/start.sh && NODE_ENV=${NODE_ENV:-development} ./scripts/start.sh",
    "build": "npx tsc",
    "unit-test": "jest",
    "create-db": "chmod +x ./database/create_database.sh && ./database/create_database.sh",
    "knex:run": "knex --knexfile database/knexfile.ts",
    "migrate:currentVersion": "npm run knex:run -- migrate:currentVersion",
    "migrate:list": "npm run knex:run -- migrate:list",
    "migrate:make": "npm run knex:run -- migrate:make",
    "migrate:seed": "npm run knex:run -- seed:run",
    "migrate:latest": "npm run knex:run -- migrate:latest",
    "migrate:rollback": "npm run knex:run -- migrate:rollback"
  },
  "author": "beniciosamuel",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/storage": "^7.19.0",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "resend": "^6.11.0",
    "zod": "^4.3.6"
  }
}
